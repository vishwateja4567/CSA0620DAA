#include <stdio.h>
#include <math.h>

float dist(float x1,float y1,float x2,float y2)
{
    return sqrt((x2-x1)*(x2-x1)+(y2-y1)*(y2-y1));
}

int main()
{
    float x[]={1,4,7,3};
    float y[]={2,5,1,6};

    float total=0;

    for(int i=0;i<3;i++)
        total+=dist(x[i],y[i],x[i+1],y[i+1]);

    total+=dist(x[3],y[3],x[0],y[0]);

    printf("Total Distance: %f",total);
}
