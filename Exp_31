#include <stdio.h>

int main()
{
    int weights[]={2,3,1};
    int values[]={4,5,3};
    int capacity=4;

    int max=0;

    for(int i=0;i<(1<<3);i++)
    {
        int w=0,v=0;

        for(int j=0;j<3;j++)
        {
            if(i&(1<<j))
            {
                w+=weights[j];
                v+=values[j];
            }
        }

        if(w<=capacity && v>max)
            max=v;
    }

    printf("Maximum Value: %d",max);
}
