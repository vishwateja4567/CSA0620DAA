#include <stdio.h>
#include <string.h>

int main()
{
    char words[4][20]={"mass","as","hero","superhero"};

    int i,j;

    for(i=0;i<4;i++)
    {
        for(j=0;j<4;j++)
        {
            if(i!=j && strstr(words[j],words[i]))
            {
                printf("%s ",words[i]);
                break;
            }
        }
    }
}
