#include <stdio.h>
#include <math.h>

float distance(int x1,int y1,int x2,int y2)
{
    return sqrt((x2-x1)*(x2-x1)+(y2-y1)*(y2-y1));
}

int main()
{
    int x[]={1,4,7,3};
    int y[]={2,5,8,1};
    int n=4;

    float min=9999;
    int p1,p2;

    for(int i=0;i<n;i++)
    {
        for(int j=i+1;j<n;j++)
        {
            float d=distance(x[i],y[i],x[j],y[j]);

            if(d<min)
            {
                min=d;
                p1=i;
                p2=j;
            }
        }
    }

    printf("Closest pair: (%d,%d) (%d,%d)\n",x[p1],y[p1],x[p2],y[p2]);
    printf("Distance: %f",min);
}
